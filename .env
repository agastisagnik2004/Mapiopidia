MAPTILER_API_KEY=XXXXXXXXXXXX

# Gmail SMTP – needed for location-sharing emails
# 1. Enable 2-Step Verification on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password and paste the 16-char code below
GMAIL_USER=XXXXXXXXXXXXX
GMAIL_APP_PASSWORD=XXXXXXXXXXXXX

# Public base URL used to build share links in emails
# Change to your deployed URL when hosting online
BASE_URL=http://127.0.0.XXXXXXXXXXXXXXX
